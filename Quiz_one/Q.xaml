<Page x:Class="Quiz_one.Q"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Quiz_one"
      mc:Ignorable="d" 
      Background="Silver"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Q">

    <Grid>
        <StackPanel HorizontalAlignment="Left">
            <Label Content="Q1 ?"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Margin="4" Content="Ans1"/>
                <RadioButton  Margin="4" Content="Ans2"/>
                <RadioButton  Margin="4" Content="Ans3"/>
            </StackPanel>

            <Label Content="Q2 ?"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Margin="4" Content="Ans1"/>
                <RadioButton  Margin="4" Content="Ans2"/>
                <RadioButton  Margin="4" Content="Ans3"/>
            </StackPanel>

            <Label Content="Q3 ?"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Margin="4" Content="Ans1"/>
                <RadioButton  Margin="4" Content="Ans2"/>
                <RadioButton  Margin="4" Content="Ans3"/>
            </StackPanel>
            <Button Content="Submit" Margin="10" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
