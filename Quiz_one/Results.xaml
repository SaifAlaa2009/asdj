<Page x:Class="Quiz_one.Results"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Quiz_one"
      mc:Ignorable="d" 
                  Background="Silver"

      d:DesignHeight="450" d:DesignWidth="800"
      Title="Results">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>

        </Grid.ColumnDefinitions>


        <StackPanel Grid.Column="0">
            <Button Margin="5"  Content="Quiz" FontSize="15" Width="150" Padding="5" Click="Button_Click"/>
            <Button Margin="5" Background="#FF39439E" Content="Results" FontSize="15" Width="150" Padding="5"/>
            <Button Margin="5" Content="Setting" FontSize="15" Width="150" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
           
            <ListBox  Margin="5,10,344,302" >
                <ListBoxItem Content="C#"/>
                <ListBoxItem Content="C++"/>
                <ListBoxItem Content="Java"/>
                <ListBoxItem Content="Html"/>
            </ListBox>

        </StackPanel>

    </Grid>
</Page>
