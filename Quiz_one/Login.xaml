<Page x:Class="Quiz_one.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Quiz_one"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">
    <Grid>
        <!--<Grid.Background>
            <ImageBrush ImageSource="/img/Back.png"></ImageBrush>
        </Grid.Background>-->

        <WrapPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

            <DockPanel Margin="20">
                <Label Content="Name" DockPanel.Dock="Left"/>
                <TextBox TextWrapping="Wrap" DockPanel.Dock="Right" Width="120"/>
            </DockPanel>



            <DockPanel Margin="20">
                <Label Content="Password"/>
                <PasswordBox Width="120"/>
            </DockPanel>

            <DockPanel Margin="20">
                <RadioButton Margin="10" Content="Student"/>
                <RadioButton Margin="10" Content="Teacher "/>
            </DockPanel>




            <CheckBox Margin="10" Content="Remmender me"/>


            <Button Margin="20" Content="Login" Click="Button_Click"/>

        </WrapPanel>

    </Grid>
</Page>
